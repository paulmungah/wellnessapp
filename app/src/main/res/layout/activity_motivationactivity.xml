<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1026">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔥 Daily Motivation"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:background="#1E1E2E"
            android:layout_marginBottom="12dp"/>

        <!-- IMAGE -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:src="@drawable/motivation"
            android:scaleType="centerCrop"
            android:layout_marginBottom="16dp"/>

        <!-- CARD 1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp"
            android:backgroundTint="#FF6D00">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Set clear goals and stay focused on your journey."
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="16dp"/>
        </androidx.cardview.widget.CardView>

        <!-- CARD 2 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp"
            android:backgroundTint="#4CAF50">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stay positive even when things get difficult."
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="16dp"/>
        </androidx.cardview.widget.CardView>

        <!-- CARD 3 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp"
            android:backgroundTint="#2979FF">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Consistency is more important than motivation."
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="16dp"/>
        </androidx.cardview.widget.CardView>

        <!-- BUTTON ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="10dp">

            <Button
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="55dp"
                android:text="BOOST"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF1744"
                android:layout_marginEnd="6dp"/>

            <Button
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="55dp"
                android:text="RESET"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FFD600"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>