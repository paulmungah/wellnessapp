<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📅 Weekly Goals"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#2C3E50"
            android:padding="16dp"
            android:background="#E3F2FD"
            android:layout_marginBottom="14dp"/>

        <!-- IMAGE -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:src="@drawable/g"
            android:scaleType="centerCrop"
            android:layout_marginBottom="16dp"/>

        <!-- CARD 1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#E8F5E9">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏋 Exercise at least 3–5 times per week to stay active."
                android:textColor="#1B5E20"
                android:textSize="16sp"
                android:padding="16dp"/>
        </androidx.cardview.widget.CardView>

        <!-- CARD 2 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#FFF3E0">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🥗 Eat balanced meals with fruits and vegetables daily."
                android:textColor="#E65100"
                android:textSize="16sp"
                android:padding="16dp"/>
        </androidx.cardview.widget.CardView>

        <!-- CARD 3 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#E3F2FD">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💧 Drink enough water every day to stay hydrated."
                android:textColor="#0D47A1"
                android:textSize="16sp"
                android:padding="16dp"/>
        </androidx.cardview.widget.CardView>

        <!-- CARD 4 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#F3E5F5">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🧘 Sleep well, relax, and keep your mind healthy."
                android:textColor="#4A148C"
                android:textSize="16sp"
                android:padding="16dp"/>
        </androidx.cardview.widget.CardView>

        <!-- BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="60dp"
                android:text="TRACK"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF5252"
                android:layout_marginEnd="6dp"/>

            <Button
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="60dp"
                android:text="EDIT"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <!-- FINAL BUTTON -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="🏆 VIEW REPORT"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFB300"
            android:layout_marginTop="14dp"/>

    </LinearLayout>

</ScrollView>