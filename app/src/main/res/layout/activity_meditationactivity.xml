<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1D26">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🧘 Meditation Zone"
            android:textSize="30sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#E0F7FA"
            android:padding="16dp"/>

        <!-- IMAGE -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:src="@drawable/meditation"
            android:scaleType="centerCrop"
            android:layout_marginBottom="20dp"/>

        <!-- TIP 1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#1E3A4C">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌿 Find a Quiet Place\nChoose a peaceful environment to relax your mind."
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="18dp"/>
        </androidx.cardview.widget.CardView>

        <!-- TIP 2 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#15616D">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌬 Focus on Breathing\nSlowly inhale and exhale to calm your mind."
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="18dp"/>
        </androidx.cardview.widget.CardView>

        <!-- TIP 3 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#0F4C5C">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🧘 Sit Comfortably\nKeep your body relaxed and posture steady."
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="18dp"/>
        </androidx.cardview.widget.CardView>

        <!-- TIP 4 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#2C7DA0">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🧠 Clear Your Mind\nLet go of stress and focus on peace."
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="18dp"/>
        </androidx.cardview.widget.CardView>

        <!-- CALM BUTTON -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="START MEDITATION"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00B4D8"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

</ScrollView>