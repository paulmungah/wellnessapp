<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:id="@+id/main"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ FITNESS DASHBOARD"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:background="#1B263B"/>

        <!-- CARD 1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            android:backgroundTint="#FF6D00">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔥 PUSH YOUR LIMITS\nDo 20 push-ups daily\nBuild strength and discipline"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:padding="20dp"/>
        </androidx.cardview.widget.CardView>

        <!-- CARD 2 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            android:backgroundTint="#4CAF50">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏃 RUNNING GOAL\n30 minutes daily jogging\nImprove stamina and heart health"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:padding="20dp"/>
        </androidx.cardview.widget.CardView>

        <!-- CARD 3 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            android:backgroundTint="#2979FF">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💪 WEIGHT TRAINING\nLift moderate weights\nBuild muscle  strength"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:padding="20dp"/>
        </androidx.cardview.widget.CardView>

        <!-- BUTTONS SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp">

            <Button
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="START WORKOUT"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF1744"
                android:layout_marginBottom="10dp"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="DAILY PROGRESS"
                android:textColor="#FFFFFF"
                android:backgroundTint="#00C853"
                android:layout_marginBottom="10dp"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="SET GOAL"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FFD600"/>
        </LinearLayout>

        <!-- ANIMATION FEEL CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="25dp"
            app:cardElevation="12dp"
            android:backgroundTint="#6A1B9A">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚀 CONSISTENCY IS POWER\nTrain daily. Stay strong. Never quit."
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:padding="22dp"
                android:gravity="center"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>